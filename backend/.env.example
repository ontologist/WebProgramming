# WP-200 Backend Configuration

# Ollama (running on same Windows 11 machine with RTX 4090)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Instructor Dashboard
INSTRUCTOR_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET

# Server
BACKEND_PORT=8001

# Database (optional - uses JSON file storage by default)
DATABASE_URL=postgresql://wp200bot:wp200bot_password@localhost:5432/wp200bot
REDIS_URL=redis://localhost:6379

# RAG
CHROMA_DB_PATH=./chroma_db
KNOWLEDGE_BASE_PATH=./knowledge_base

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
